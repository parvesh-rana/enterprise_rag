# Copy to .env and fill in. Never commit .env.

# --- LLM provider (default: NVIDIA NIM, OpenAI-compatible) ---
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=deepseek-ai/deepseek-v3.1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# --- Optional alternate providers ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# --- Embeddings & reranker ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=20
FINAL_TOP_K=5

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=filings_v1

# --- SEC EDGAR (User-Agent is required by SEC; use a real contact) ---
EDGAR_USER_AGENT=Enterprise RAG Demo contact@example.com

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT_PER_MINUTE=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
